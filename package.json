{
  "name": "meanwhile",
  "version": "0.1.1",
  "description": "The open control plane for running any coding agent in any isolated runtime.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "workspaces": [
    "providers/cloudflare-sandbox"
  ],
  "exports": {
    ".": "./src/client.ts",
    "./contracts": "./src/api/contracts.ts",
    "./timeline": "./src/timeline.ts",
    "./workspace": "./src/workspace.ts"
  },
  "bin": {
    "meanwhile": "./src/cli.ts"
  },
  "scripts": {
    "predev": "bun run runtime:build",
    "dev": "bun --watch src/server.ts",
    "prestart": "bun run runtime:build",
    "start": "bun src/server.ts",
    "cli": "bun src/cli.ts",
    "doctor": "bun src/cli.ts doctor",
    "predemo": "bun run runtime:build",
    "demo": "bun scripts/demo.ts",
    "demo:codex": "bun scripts/demo.ts --codex",
    "demo:codex:serve": "bun scripts/demo.ts --codex --serve",
    "demo:claude": "bun scripts/demo.ts --claude",
    "demo:claude:serve": "bun scripts/demo.ts --claude --serve",
    "demo:pi": "bun scripts/demo.ts --pi",
    "demo:pi:serve": "bun scripts/demo.ts --pi --serve",
    "preproof:release": "bun run runtime:build",
    "proof:release": "bun scripts/release-proof.ts --provider=local",
    "proof:release:local:codex": "bun scripts/release-proof.ts --provider=local --agent=codex",
    "proof:release:local:claude": "bun scripts/release-proof.ts --provider=local --agent=claude-code",
    "proof:release:local:pi": "bun scripts/release-proof.ts --provider=local --agent=pi",
    "preproof:release:cloudflare": "bun run runtime:build",
    "proof:release:cloudflare": "bun scripts/release-proof.ts --provider=cloudflare --require-provenance",
    "proof:release:cloudflare:codex": "bun scripts/release-proof.ts --provider=cloudflare --agent=codex --require-provenance",
    "proof:release:cloudflare:claude": "bun scripts/release-proof.ts --provider=cloudflare --agent=claude-code --require-provenance",
    "proof:release:cloudflare:pi": "bun scripts/release-proof.ts --provider=cloudflare --agent=pi --require-provenance",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check . && tsc --noEmit && bun run notices:check && bun run runtime:build && bun test",
    "notices:prepare": "rm -rf node_modules providers/cloudflare-sandbox/node_modules providers/cloudflare-sandbox/image/node_modules && bun install --frozen-lockfile && bun install --cwd providers/cloudflare-sandbox/image --frozen-lockfile --production --os=linux --cpu=x64",
    "notices:generate": "bun run notices:prepare && bun scripts/third-party-notices.ts --write",
    "notices:check": "bun run notices:prepare && bun scripts/third-party-notices.ts --check",
    "test:live:cloudflare": "MEANWHILE_LIVE_CLOUDFLARE=1 bun test ./test/live/cloudflare-sandbox.test.ts",
    "runner:build": "bun build runner/main.ts --compile --minify --outfile dist/meanwhile-runner",
    "demo-agent:build": "bun build test/fixtures/acp-agent.ts --compile --minify --outfile dist/meanwhile-demo-agent",
    "runtime:build": "bun run runner:build && bun run demo-agent:build",
    "cloudflare:check": "bun run --cwd providers/cloudflare-sandbox check",
    "cloudflare:dev": "bun run --cwd providers/cloudflare-sandbox dev",
    "cloudflare:deploy": "bun run --cwd providers/cloudflare-sandbox deploy"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@hono/zod-openapi": "1.4.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}

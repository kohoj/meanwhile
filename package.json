{
  "name": "@kohoz/meanwhile",
  "version": "0.1.3",
  "description": "The trusted system for work you delegate to AI agents: run any ACP coding agent in an isolated runtime with durable, recoverable, auditable, credential-mediated execution.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kohoj/meanwhile.git"
  },
  "homepage": "https://github.com/kohoj/meanwhile#readme",
  "bugs": {
    "url": "https://github.com/kohoj/meanwhile/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "runner",
    "config",
    "providers/cloudflare-sandbox/src/protocol.ts",
    "tsconfig.json",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES"
  ],
  "workspaces": [
    "providers/cloudflare-sandbox",
    "board"
  ],
  "exports": {
    ".": "./src/client.ts",
    "./contracts": "./src/api/contracts.ts",
    "./timeline": "./src/timeline.ts",
    "./workspace": "./src/workspace.ts"
  },
  "bin": {
    "meanwhile": "src/cli.ts"
  },
  "scripts": {
    "predev": "bun run runtime:build",
    "dev": "bun --watch src/server.ts",
    "prestart": "bun run runtime:build",
    "start": "bun src/server.ts",
    "cli": "bun src/cli.ts",
    "doctor": "bun src/cli.ts doctor",
    "migrate:projects": "bun scripts/migrate-project-collaboration.ts",
    "predemo": "bun run runtime:build",
    "demo": "bun scripts/demo.ts",
    "demo:serve": "bun scripts/demo.ts --serve",
    "proof:release:execute": "bun run runtime:build && bun scripts/release-proof.ts",
    "proof:release": "bun run proof:release:execute -- --provider=local --output=.proof/local-demo.json",
    "proof:release:cloudflare": "bun run proof:release:execute -- --provider=cloudflare --require-provenance --output=.proof/cloudflare-demo.json",
    "proof:release:cloudflare:codex": "bun run proof:release:execute -- --provider=cloudflare --agent=codex --require-provenance --output=.proof/cloudflare-codex.json",
    "proof:release:cloudflare:claude": "bun run proof:release:execute -- --provider=cloudflare --agent=claude-code --require-provenance --output=.proof/cloudflare-claude-code.json",
    "proof:release:cloudflare:pi": "bun run proof:release:execute -- --provider=cloudflare --agent=pi --require-provenance --output=.proof/cloudflare-pi.json",
    "proof:verify": "bun scripts/verify-release-proof.ts",
    "proof:project-collaboration:execute": "bun run runtime:build && bun run board:build && bun scripts/project-collaboration-proof.ts",
    "proof:project-collaboration": "bun run proof:project-collaboration:execute -- --output=.proof/project-collaboration.json",
    "proof:project-collaboration:verify": "bun scripts/verify-project-collaboration-proof.ts",
    "proof:deployed-collaboration": "bun scripts/deployed-collaboration-proof.ts --require-clean --output=.proof/deployed-project-collaboration.json",
    "proof:deployed-collaboration:verify": "bun scripts/verify-deployed-collaboration-proof.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check . && tsc --noEmit && bun run notices:check && bun run runtime:build && bun test",
    "notices:prepare": "rm -rf node_modules providers/cloudflare-sandbox/node_modules providers/cloudflare-sandbox/image/node_modules && bun install --frozen-lockfile && bun install --cwd providers/cloudflare-sandbox/image --frozen-lockfile --production --os=linux --cpu=x64",
    "notices:generate": "bun run notices:prepare && bun scripts/third-party-notices.ts --write",
    "notices:check": "bun run notices:prepare && bun scripts/third-party-notices.ts --check",
    "test:live:cloudflare": "MEANWHILE_LIVE_CLOUDFLARE=1 bun test ./test/live/cloudflare-sandbox.test.ts",
    "runner:build": "bun build runner/main.ts --compile --minify --outfile dist/meanwhile-runner",
    "demo-agent:build": "bun build test/fixtures/acp-agent.ts --compile --minify --outfile dist/meanwhile-demo-agent",
    "runtime:build": "bun run runner:build && bun run demo-agent:build",
    "board:check": "bun run --cwd board check",
    "board:build": "bun run --cwd board build",
    "board:dev": "bun run --cwd board build && bun run --cwd board dev",
    "cloudflare:check": "bun run --cwd providers/cloudflare-sandbox check",
    "cloudflare:dev": "bun scripts/stage-cloudflare-runner.ts && bun run --cwd providers/cloudflare-sandbox dev:staged",
    "cloudflare:deploy": "bun scripts/stage-cloudflare-runner.ts && bun run --cwd providers/cloudflare-sandbox deploy:staged",
    "cloudflare:image:check": "bun scripts/stage-cloudflare-runner.ts && bun run --cwd providers/cloudflare-sandbox image:check:staged"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@hono/zod-openapi": "1.4.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-metrics": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}

# Optional runtime-only environment for compose.yaml.
#
# Copy this file to compose.env, or point MEANWHILE_ENV_FILE at another file.
# Compose treats the file as optional. Keep it uncommitted and inject production
# values from a secret platform instead.

# Bound new execution admission without weakening restart reconciliation.
# MEANWHILE_RUN_CONCURRENCY=2
# MEANWHILE_SESSION_CONCURRENCY=2

# Project Watch runs as a separate, credential-free BFF in compose.yaml. Put an
# HTTPS reverse proxy in front of port 7333 for access from other machines; keep
# the control-plane API and preview ports private unless an operator explicitly
# needs them. Each person signs in to Project Watch with their own Principal-bound
# API key, which is exchanged once for an opaque read-only browser session.

# Register and optionally select the remote provider.
# MEANWHILE_DEFAULT_PROVIDER=cloudflare
# CLOUDFLARE_BRIDGE_URL=https://meanwhile-sandbox.example.workers.dev
# CLOUDFLARE_BRIDGE_TOKEN=<high-entropy bridge credential>
# CLOUDFLARE_RUNNER_DIGEST=<64 lowercase hex characters>
# CLOUDFLARE_RUNTIME_IMAGE_REFERENCE=<deployed custom image reference>
# CLOUDFLARE_RUNTIME_IMAGE_DIGEST=sha256:<64 lowercase hex characters>

# Only names explicitly listed here may be resolved by the local bootstrap owner's
# env:// secret references. Source and target names must match; reserved control-plane
# and provider variables are rejected. Values pass through this file without
# enumerating agent credential names in compose.yaml.
# MEANWHILE_SECRET_ENV_ALLOWLIST=OPENAI_API_KEY,ANTHROPIC_API_KEY
# OPENAI_API_KEY=<agent-scoped credential>
# ANTHROPIC_API_KEY=<agent-scoped credential>

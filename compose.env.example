# Optional runtime-only environment for compose.yaml.
#
# Copy this file to compose.env, or point MEANWHILE_ENV_FILE at another file.
# Compose treats the file as optional. Keep it uncommitted and inject production
# values from a secret platform instead.

# Bound new execution admission without weakening restart reconciliation.
# MEANWHILE_RUN_CONCURRENCY=2
# MEANWHILE_SESSION_CONCURRENCY=2

# Host-loopback ports can be moved when running a second isolated installation.
# These variables configure Compose interpolation and are not application secrets.
# Export them in the shell or pass them through `docker compose --env-file`.
# MEANWHILE_CONTROL_PLANE_HOST_PORT=7331
# MEANWHILE_PREVIEW_HOST_PORT=7332
# MEANWHILE_BOARD_HOST_PORT=7333

# Project Watch runs as a separate, credential-free BFF in compose.yaml. Put an
# HTTPS reverse proxy in front of port 7333 for access from other machines; keep
# the control-plane API and preview ports private unless an operator explicitly
# needs them. Each person signs in to Project Watch with their own Principal-bound
# API key, which is exchanged once for an opaque deny-by-default browser session.

# Optional Cloudflare Tunnel overlay. Create one remotely managed tunnel, store
# its token in a chmod-600 file outside this repository, and configure published
# application routes to `http://project-watch:7333` for the Board and, only when
# remote CLI/SDK or deployed-system proof requires it, `http://meanwhile:7331`
# for the authenticated API. Never publish port 7332.
# CLOUDFLARE_TUNNEL_TOKEN_FILE=/absolute/path/to/meanwhile-tunnel.token

# Optional linked GitHub/Google sign-in. Callback URLs terminate at the public
# Project Watch origin, not at the private control-plane origin. The GitHub App
# must use expiring user access tokens and Contents read permission for private
# checkout. Generate the vault key out of band; never commit a real value.
# MEANWHILE_EXTERNAL_AUTH_OWNER_ID=00000000-0000-4000-8000-000000000001
# Set to open only when anyone admitted by a configured provider may create a
# stable member Principal inside this exact Owner.
# MEANWHILE_EXTERNAL_REGISTRATION=closed
# MEANWHILE_IDENTITY_CREDENTIAL_KEY=<43-character base64url value>
# MEANWHILE_IDENTITY_CREDENTIAL_KEY_VERSION=v1
# MEANWHILE_GITHUB_CLIENT_ID=
# MEANWHILE_GITHUB_CLIENT_SECRET=
# MEANWHILE_GITHUB_CALLBACK_URL=https://watch.example.com/auth/github/callback
# MEANWHILE_GOOGLE_CLIENT_ID=
# MEANWHILE_GOOGLE_CLIENT_SECRET=
# MEANWHILE_GOOGLE_CALLBACK_URL=https://watch.example.com/auth/google/callback

# Register and optionally select the remote provider.
# MEANWHILE_DEFAULT_PROVIDER=cloudflare
# CLOUDFLARE_BRIDGE_URL=https://meanwhile-sandbox.example.workers.dev
# CLOUDFLARE_BRIDGE_TOKEN=<high-entropy bridge credential>
# CLOUDFLARE_RUNNER_DIGEST=<64 lowercase hex characters>
# CLOUDFLARE_RUNTIME_IMAGE_REFERENCE=<deployed custom image reference>
# CLOUDFLARE_RUNTIME_IMAGE_DIGEST=sha256:<64 lowercase hex characters>

# Only names explicitly listed here may be resolved by the local bootstrap owner's
# env:// secret references. Source and target names must match; reserved control-plane
# and provider variables are rejected. Values pass through this file without
# enumerating agent credential names in compose.yaml.
# MEANWHILE_SECRET_ENV_ALLOWLIST=OPENAI_API_KEY,ANTHROPIC_API_KEY
# OPENAI_API_KEY=<agent-scoped credential>
# ANTHROPIC_API_KEY=<agent-scoped credential>

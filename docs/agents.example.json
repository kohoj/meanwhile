{
  "version": 1,
  "agents": {
    "codex": {
      "transport": "stdio",
      "executable": "codex-acp",
      "args": [],
      "workingDirectory": "workspace",
      "capabilities": {
        "filesystem": true,
        "terminal": true
      },
      "envNames": ["CI"],
      "networkPolicy": { "allowedHosts": ["api.openai.com"] },
      "credentials": [
        {
          "environmentVariable": "OPENAI_API_KEY",
          "host": "api.openai.com",
          "methods": ["POST"]
        }
      ]
    },
    "claude-code": {
      "transport": "stdio",
      "executable": "claude-agent-acp",
      "args": [],
      "workingDirectory": "workspace",
      "capabilities": {
        "filesystem": true,
        "terminal": true
      },
      "envNames": [
        "CI",
        "CLAUDE_CODE_DISABLE_AUTO_MEMORY",
        "CLAUDE_CODE_DISABLE_AGENT_VIEW",
        "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS",
        "CLAUDE_CODE_ATTRIBUTION_HEADER",
        "CLAUDE_CODE_USE_VERTEX",
        "ANTHROPIC_VERTEX_PROJECT_ID",
        "ANTHROPIC_BASE_URL"
      ],
      "networkPolicy": { "allowedHosts": ["api.anthropic.com"] },
      "credentials": [
        {
          "environmentVariable": "ANTHROPIC_API_KEY",
          "host": "api.anthropic.com",
          "methods": ["POST"]
        }
      ]
    },
    "pi": {
      "transport": "stdio",
      "executable": "pi-acp",
      "args": [],
      "workingDirectory": "workspace",
      "capabilities": {
        "filesystem": true,
        "terminal": true
      },
      "envNames": ["AWS_REGION", "PI_TELEMETRY"],
      "networkPolicy": {
        "allowedHosts": ["bedrock-runtime.us-east-1.amazonaws.com"]
      },
      "credentials": [
        {
          "environmentVariable": "AWS_BEARER_TOKEN_BEDROCK",
          "host": "bedrock-runtime.us-east-1.amazonaws.com",
          "methods": ["POST"]
        }
      ]
    },
    "hermes": {
      "transport": "stdio",
      "executable": "hermes-acp",
      "args": [],
      "workingDirectory": "workspace",
      "capabilities": {
        "filesystem": true,
        "terminal": true
      },
      "envNames": ["CI"],
      "networkPolicy": { "allowedHosts": ["api.openai.com"] },
      "credentials": [
        {
          "environmentVariable": "OPENAI_API_KEY",
          "host": "api.openai.com",
          "methods": ["POST"]
        }
      ]
    }
  }
}

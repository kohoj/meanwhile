{
  "version": 1,
  "agents": {
    "codex": {
      "transport": "stdio",
      "executable": "codex-acp",
      "args": [],
      "workingDirectory": "workspace",
      "capabilities": {
        "filesystem": true,
        "terminal": true
      },
      "envNames": ["CI"],
      "secretEnvNames": ["OPENAI_API_KEY"]
    },
    "claude-code": {
      "transport": "stdio",
      "executable": "claude-agent-acp",
      "args": [],

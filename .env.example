# Meanwhile local development configuration.
# Copy to .env, then append a newly generated MEANWHILE_API_KEY.
# Never commit .env or place production credentials in this file.

# API server. Keep loopback binding for the local provider and bootstrap key.
MEANWHILE_HOST=127.0.0.1
MEANWHILE_PORT=7331

# Untrusted static previews use a separate origin from the authenticated API.
MEANWHILE_PREVIEW_HOST=127.0.0.1
MEANWHILE_PREVIEW_PORT=7332
# Required for 0.0.0.0/:: binds; browser-facing HTTP(S) origin without a path.
# MEANWHILE_PREVIEW_PUBLIC_URL=https://previews.example.com

# One durable root; SQLite, artifacts, and local runtime state are derived below it.
MEANWHILE_DATA_DIR=./data

# debug | info | warn | error
MEANWHILE_LOG_LEVEL=info

# Local bootstrap only. Generate at least 32 random bytes; do not reuse in production.
# Production API keys are shown once and persisted only as hashes.
# MEANWHILE_API_KEY=

# Fixed standalone Bun runner and the one validated agent catalog.
MEANWHILE_RUNNER_PATH=./dist/meanwhile-runner
MEANWHILE_AGENT_CATALOG=./config/agents.json
MEANWHILE_DEFAULT_PROVIDER=local
# auto enables host execution only when the API binds loopback. Use disabled for
# an untrusted deployment; non-loopback enabled requires an explicit unsafe ack.
MEANWHILE_LOCAL_PROVIDER=auto
MEANWHILE_ALLOW_UNSAFE_LOCAL_PROVIDER=false

# OpenTelemetry is opt-in until the exact pinned SDK/exporter passes its Bun test.
MEANWHILE_OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Cloudflare Sandbox bridge. Required only when the cloudflare provider is enabled.
# The token value must match the bridge-side BRIDGE_TOKEN binding.
# Never expose the bridge token to a runner or agent process.
# CLOUDFLARE_BRIDGE_URL=https://meanwhile-sandbox.example.workers.dev
# CLOUDFLARE_BRIDGE_TOKEN=
# Optional for ordinary runs, required by proof:release:cloudflare.
# CLOUDFLARE_RUNNER_DIGEST=<64 lowercase hex characters>
# CLOUDFLARE_RUNTIME_IMAGE_DIGEST=sha256:<64 lowercase hex characters>

# Agent/model credentials are referenced as env://NAME in a run's secretRefs.
# Only the local bootstrap owner may use this process-environment catalog, and
# agent/deployment source names must equal their declared environment targets.
# Empty denies all sources. Repository credentials require a host-scoped broker;
# the process-environment catalog intentionally cannot authorize checkout tokens.
# Leave real values in the deployment secret manager or local uncommitted .env only.
# MEANWHILE_SECRET_ENV_ALLOWLIST=OPENAI_API_KEY,ANTHROPIC_API_KEY
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
